{
  "name": "apilix",
  "version": "1.0.0-beta.22",
  "description": "APILIX - API Lightweight Interface eXplorer",
  "main": "electron/main.js",
  "bin": {
    "apilix": "bin/apilix.js"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=9"
  },
  "scripts": {
    "start": "concurrently -k -p \"[{name}]\" -n \"SERVER,CLIENT\" -c \"bgYellow.bold,bgCyan.bold\" \"npm run server\" \"npm run client\"",
    "cli": "node bin/apilix.js",
    "cli:help": "node bin/apilix.js --help",
    "cli:build:binaries": "pkg . --public --public-packages \"*\" --targets node20-macos-x64,node20-linux-x64,node20-win-x64 --out-path dist/cli",
    "server": "node server/index.js",
    "test": "cd server && npm test && cd ../client && npm test",
    "test:server": "cd server && npm test",
    "test:client": "cd client && npm test",
    "client": "cd client && npm run dev",
    "setup": "npm install && cd server && npm install && cd ../client && npm install",
    "build": "cd client && npm run build",
    "electron": "electron .",
    "electron:dev": "concurrently -k -p \"[{name}]\" -n \"SERVER,CLIENT,ELECTRON\" -c \"bgYellow.bold,bgCyan.bold,bgMagenta.bold\" \"npm run server\" \"npm run client\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:prod": "npm run build && DISABLE_DEVTOOLS=1 electron-builder",
    "dist:prod:mac": "npm run build && DISABLE_DEVTOOLS=1 electron-builder --mac",
    "dist:prod:win": "npm run build && DISABLE_DEVTOOLS=1 electron-builder --win"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.908.0",
    "@aws-sdk/s3-request-presigner": "^3.908.0",
    "chalk": "^4.1.2",
    "commander": "^14.0.1",
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.18.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "wait-on": "^8.0.0"
  },
  "pkg": {
    "scripts": [
      "bin/**/*.js",
      "src/**/*.js",
      "server/cli-runner.js",
      "server/collectionRunner.js",
      "server/executor.js",
      "server/oauth.js",
      "server/runnerReporters.js",
      "server/sandbox.js",
      "server/tlsUtils.js"
    ],
    "assets": [
      "server/node_modules/**/*.cjs"
    ],
    "targets": [
      "node20-macos-x64",
      "node20-linux-x64",
      "node20-win-x64"
    ],
    "outputPath": "dist/cli"
  },
  "build": {
    "appId": "com.apilix.app",
    "productName": "Apilix",
    "files": [
      "electron/**/*",
      "client/dist/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "server/node_modules",
        "to": "server/node_modules"
      },
      {
        "from": "src/core",
        "to": "src/core",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    }
  }
}
