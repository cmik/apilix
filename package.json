{
  "name": "apilix",
  "version": "1.0.0-beta.24",
  "description": "APILIX - API Lightweight Interface eXplorer",
  "main": "electron/main.js",
  "bin": {
    "apilix": "bin/apilix.js"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=9"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "concurrently -k -p \"[{name}]\" -n \"SERVER,CLIENT\" -c \"bgYellow.bold,bgCyan.bold\" \"npm run server\" \"npm run client\"",
    "cli": "node bin/apilix.js",
    "cli:help": "node bin/apilix.js --help",
    "cli:build:binaries": "pkg . --no-bytecode --public --public-packages \"*\" --compress GZip --targets node20-macos-x64,node20-linux-x64,node20-win-x64 --out-path dist/cli",
    "server": "node packages/server/index.js",
    "test": "npm test -w @apilix/server && npm test -w @apilix/client",
    "test:server": "npm test -w @apilix/server",
    "test:client": "npm test -w @apilix/client",
    "test:core": "npm test -w @apilix/core",
    "test:cli": "npm test -w @apilix/cli",
    "client": "npm run dev -w @apilix/client",
    "setup": "npm install",
    "build": "npm run build -w @apilix/client",
    "electron": "electron .",
    "electron:dev": "concurrently -k -p \"[{name}]\" -n \"SERVER,CLIENT,ELECTRON\" -c \"bgYellow.bold,bgCyan.bold,bgMagenta.bold\" \"npm run server\" \"npm run client\" \"wait-on http://localhost:5173 && electron .\"",
    "dist:prepare:server": "npm install --prefix packages/server --omit=dev --install-links",
    "dist": "npm run dist:prepare:server && npm run build && electron-builder",
    "dist:mac": "npm run dist:prepare:server && npm run build && electron-builder --mac",
    "dist:win": "npm run dist:prepare:server && npm run build && electron-builder --win",
    "dist:prod": "npm run dist:prepare:server && npm run build && DISABLE_DEVTOOLS=1 electron-builder",
    "dist:prod:mac": "npm run dist:prepare:server && npm run build && DISABLE_DEVTOOLS=1 electron-builder --mac",
    "dist:prod:win": "npm run dist:prepare:server && npm run build && DISABLE_DEVTOOLS=1 electron-builder --win"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.18.2",
    "@apilix/server": "*",
    "concurrently": "^8.2.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "wait-on": "^8.0.0"
  },
  "pkg": {
    "scripts": [
      "bin/apilix.js",
      "packages/cli/src/index.js",
      "packages/core/src/index.js"
    ],
    "assets": [
      "node_modules/csv-parse/dist/cjs/sync.cjs"
    ],
    "targets": [
      "node20-macos-x64",
      "node20-linux-x64",
      "node20-win-x64"
    ],
    "outputPath": "dist/cli"
  },
  "build": {
    "appId": "com.apilix.app",
    "productName": "Apilix",
    "files": [
      "electron/**/*",
      "packages/client/dist/**/*",
      "!node_modules/@apilix",
      "node_modules/**/*"
    ],
    "asarUnpack": [],
    "extraResources": [
      {
        "from": "packages/server",
        "to": "packages/server",
        "filter": ["**/*", "!node_modules/**"]
      },
      {
        "from": "packages/server/node_modules",
        "to": "packages/server/node_modules",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    }
  }
}
