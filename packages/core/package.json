{
  "name": "@apilix/core",
  "version": "1.0.0-beta.23",
  "description": "Apilix request engine, script runtime, OAuth, TLS utils, collection runner, and shared reporters",
  "main": "src/index.js",
  "types": "types/index.ts",
  "exports": {
    ".": {
      "require": "./src/index.js",
      "default": "./src/index.js"
    },
    "./request-engine": {
      "require": "./src/request-engine.js",
      "default": "./src/request-engine.js"
    },
    "./script-runtime": {
      "require": "./src/script-runtime.js",
      "default": "./src/script-runtime.js"
    },
    "./collection-runner": {
      "require": "./src/collection-runner.js",
      "default": "./src/collection-runner.js"
    },
    "./oauth": {
      "require": "./src/oauth.js",
      "default": "./src/oauth.js"
    },
    "./tls-utils": {
      "require": "./src/tls-utils.js",
      "default": "./src/tls-utils.js"
    },
    "./runner-reporters": {
      "require": "./src/runner-reporters.js",
      "default": "./src/runner-reporters.js"
    },
    "./variable-resolver": {
      "require": "./src/variable-resolver.js",
      "default": "./src/variable-resolver.js"
    },
    "./types": "./types/index.ts"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "test": "node --test"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.9",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "axios": "^1.15.2",
    "csv-parse": "^5.5.3",
    "form-data": "^4.0.0",
    "xpath": "^0.0.34"
  },
  "optionalDependencies": {
    "win-ca": "^3.5.1"
  }
}
